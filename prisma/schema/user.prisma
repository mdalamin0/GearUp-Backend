model User {
  id String @id @default(uuid())
  name String 
  email String @unique
  password String
  role  Role @default(CUSTOMER)
  status UserStatus @default(ACTIVE)
  gearItems GearItem[]
  rentalOrders RentalOrder[]
  reviews Review[]
  
  createdAt DateTime @default(now())
  updatedAT DateTime @updatedAt

  @@map("users")
}